{
	"name": "@orquestra/vitest",
	"version": "3.1.0",
	"description": "Vitest bridge for Orquestra — code-first BDD scenarios with services, modules, macros, attach/log on top of Vitest.",
	"type": "module",
	"main": "dist/index.esm.js",
	"module": "dist/index.esm.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.esm.js"
		},
		"./plugin": {
			"types": "./dist/plugin.d.ts",
			"import": "./dist/plugin.esm.js",
			"require": "./dist/plugin.cjs"
		}
	},
	"license": "MIT",
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=22"
	},
	"author": {
		"email": "contato@gabrieljs.dev",
		"name": "Gabriel de Jesus Silva",
		"url": "https://gabrieljs.dev"
	},
	"scripts": {
		"prebuild": "rimraf -g dist",
		"build": "rollup -c"
	},
	"dependencies": {
		"@orquestra/core": "^3.1.0"
	},
	"peerDependencies": {
		"vitest": ">=2.0.0"
	},
	"devDependencies": {
		"@rollup/plugin-commonjs": "^26.0.1",
		"@rollup/plugin-json": "^6.1.0",
		"@rollup/plugin-node-resolve": "^15.2.3",
		"@rollup/plugin-typescript": "^11.1.6",
		"@types/node": "^22.0.0",
		"rimraf": "^6.0.1",
		"rollup": "^4.19.0",
		"tslib": "^2.6.3",
		"typescript": "^5.9.3",
		"vite": "^7.0.0"
	},
	"publishConfig": {
		"access": "public"
	}
}
