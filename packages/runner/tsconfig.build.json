{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"rootDir": "./src",
		"outDir": "./dist",
		"typeRoots": ["../../node_modules/@types"],
		"types": ["node"],
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"strict": false
	},
	"include": ["src/**/*"],
	"exclude": ["**/*.test.ts", "**/*.spec.ts"]
}
